    "keybindings": [
      {
        "command": "editless.focusSession",
        "key": "ctrl+shift+s",
        "mac": "cmd+shift+s"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "editless.refresh",
          "when": "view == editlessTree",
          "group": "navigation@1"
        },
        {
          "command": "editless.addNew",
          "when": "view == editlessTree",
          "group": "navigation@2"
        },
        {
          "command": "editless.refreshWorkItems",
          "when": "view == editlessWorkItems",
          "group": "navigation@1"
        },
        {
          "command": "editless.filterWorkItems",
          "when": "view == editlessWorkItems",
          "group": "navigation@2"
        },
        {
          "command": "editless.clearWorkItemsFilter",
          "when": "view == editlessWorkItems && editless.workItemsFiltered",
          "group": "navigation@3"
        },
        {
          "command": "editless.configureWorkItems",
          "when": "view == editlessWorkItems",
          "group": "navigation@4"
        },
        {
          "command": "editless.refreshPRs",
          "when": "view == editlessPRs",
          "group": "navigation@1"
        },
        {
          "command": "editless.prs.toggleMyPRs",
          "when": "view == editlessPRs && !editless.prsMyOnly",
          "group": "navigation@2"
        },
        {
          "command": "editless.prs.toggleMyPRs",
          "when": "view == editlessPRs && editless.prsMyOnly",
          "group": "navigation@2"
        },
        {
          "command": "editless.filterPRs",
          "when": "view == editlessPRs",
          "group": "navigation@3"
        },
        {
          "command": "editless.clearPRsFilter",
          "when": "view == editlessPRs && editless.prsFiltered",
          "group": "navigation@4"
        },
        {
          "command": "editless.configurePRs",
          "when": "view == editlessPRs",
          "group": "navigation@5"
        }
      ],
      "view/item/context": [
        {
          "command": "editless.launchSession",
          "when": "view == editlessTree && viewItem =~ /^squad|^squad-hidden|^agent|^default-agent$/",
          "group": "inline@0"
        },
        {
          "command": "editless.launchSession",
          "when": "view == editlessTree && viewItem =~ /^squad|^squad-hidden|^agent|^default-agent$/",
          "group": "session@0"
        },
        {
          "command": "editless.resumeSession",
          "when": "view == editlessTree && viewItem =~ /^squad|^squad-hidden|^agent|^default-agent$/",
          "group": "session@1"
        },
        {
          "command": "editless.renameSquad",
          "when": "view == editlessTree && viewItem =~ /^squad|^squad-hidden/",
          "group": "squad@1"
        },
        {
          "command": "editless.changeModel",
          "when": "view == editlessTree && viewItem =~ /^squad|^squad-hidden/",
          "group": "squad@2"
        },
        {
          "command": "editless.goToSquadSettings",
          "when": "view == editlessTree && viewItem =~ /^squad|^squad-hidden/",
          "group": "squad@3"
        },
        {
          "command": "editless.openInSquadUi",
          "when": "view == editlessTree && viewItem =~ /^squad|^squad-hidden/ && editless.squadUiSupportsDeepLink",
          "group": "squad@4"
        },
        {
          "command": "editless.hideAgent",
          "when": "view == editlessTree && viewItem == squad",
          "group": "squad@5"
        },
        {
          "command": "editless.closeTerminal",
          "when": "viewItem == terminal"
        },
        {
          "command": "editless.closeTerminal",
          "when": "viewItem == terminal",
          "group": "inline@99"
        },
        {
          "command": "editless.renameSession",
          "when": "viewItem == terminal"
        },
        {
          "command": "editless.clearSessionLabel",
          "when": "viewItem == terminal"
        },
        {
          "command": "editless.launchFromWorkItem",
          "when": "view == editlessWorkItems && viewItem =~ /^(work-item|ado-work-item|ado-parent-item|local-task)$/",
          "group": "inline@0"
        },
        {
          "command": "editless.openTaskFile",
          "when": "view == editlessWorkItems && viewItem == local-task",
          "group": "inline@1"
        },
        {
          "command": "editless.openInBrowser",
          "when": "viewItem =~ /^(work-item|ado-work-item|ado-parent-item)$/",
          "group": "inline@1"
        },
        {
          "command": "editless.launchFromWorkItem",
          "when": "viewItem =~ /^(work-item|ado-work-item|ado-parent-item|local-task)$/",
          "group": "work-item@1"
        },
        {
          "command": "editless.openTaskFile",
          "when": "viewItem == local-task",
          "group": "work-item@2"
        },
        {
          "command": "editless.openInBrowser",
          "when": "viewItem =~ /^(work-item|ado-work-item|ado-parent-item)$/",
          "group": "work-item@3"
        },
        {
          "command": "editless.launchFromPR",
          "when": "view == editlessPRs && viewItem =~ /^(pull-request|ado-pull-request)$/",
          "group": "inline@0"
        },
        {
          "command": "editless.openInBrowser",
          "when": "viewItem =~ /^(pull-request|ado-pull-request)$/",
          "group": "inline@1"
        },
        {
          "command": "editless.launchFromPR",
          "when": "viewItem =~ /^(pull-request|ado-pull-request)$/",
          "group": "pull-request@1"
        },
        {
          "command": "editless.openInBrowser",
          "when": "viewItem =~ /^(pull-request|ado-pull-request)$/",
          "group": "pull-request@2"
        },
        {
          "command": "editless.relaunchSession",
          "when": "viewItem == orphanedSession",
          "group": "inline@1"
        },
        {
          "command": "editless.dismissOrphan",
          "when": "viewItem == orphanedSession",
          "group": "inline@2"
        },
        {
          "command": "editless.filterLevel",
          "when": "view == editlessWorkItems && viewItem =~ /^(ado|github|local)-(backend|org|project|repo|folder)(-filtered)?$/",
          "group": "inline@1"
        },
        {
          "command": "editless.clearLevelFilter",
          "when": "view == editlessWorkItems && viewItem =~ /-filtered$/",
          "group": "inline@2"
        },
        {
          "command": "editless.filterLevel",
          "when": "view == editlessWorkItems && viewItem =~ /^(ado|github|local)-(backend|org|project|repo|folder)(-filtered)?$/",
          "group": "filter@1"
        },
        {
          "command": "editless.clearLevelFilter",
          "when": "view == editlessWorkItems && viewItem =~ /^(ado|github|local)-(backend|org|project|repo|folder)-filtered$/",
          "group": "filter@2"
        },
        {
          "command": "editless.filterPRLevel",
          "when": "view == editlessPRs && viewItem =~ /^(ado|github)-pr-(backend|org|project|repo)(-filtered)?$/",
          "group": "inline@1"
        },
        {
          "command": "editless.clearPRLevelFilter",
          "when": "view == editlessPRs && viewItem =~ /-filtered$/",
          "group": "inline@2"
        },
        {
          "command": "editless.filterPRLevel",
          "when": "view == editlessPRs && viewItem =~ /^(ado|github)-pr-(backend|org|project|repo)(-filtered)?$/",
          "group": "filter@1"
        },
        {
          "command": "editless.clearPRLevelFilter",
          "when": "view == editlessPRs && viewItem =~ /^(ado|github)-pr-(backend|org|project|repo)-filtered$/",
          "group": "filter@2"
        },
        {
          "command": "editless.showAgent",
          "when": "view == editlessTree && viewItem == squad-hidden",
          "group": "squad@5"
        }
      ],
