        {
          "command": "editless.prs.toggleMyPRs",
          "when": "false"
        },
        {
          "command": "editless.filterPRs",
          "when": "false"
        },
        {
          "command": "editless.clearPRsFilter",
          "when": "false"
        },
        {
          "command": "editless.configurePRs",
          "when": "false"
        },
        {
          "command": "editless.openInBrowser",
          "when": "false"
        },
        {
          "command": "editless.launchFromWorkItem",
          "when": "false"
        },
        {
          "command": "editless.openFilePreview",
          "when": "false"
        },
        {
          "command": "editless.goToPR",
          "when": "false"
        },
        {
          "command": "editless.configureRepos",
          "when": "false"
        },
        {
          "command": "editless.configureAdo",
          "when": "false"
        },
        {
          "command": "editless.addNew",
          "when": "false"
